    {
      "parameters": {
        "jsCode": "// Build the plain-text welcome menu.\n// This is sent ONLY when a greeting is detected, so no specialist agent\n// is invoked and no duplicate message is produced.\nconst name = $input.item.json.senderName || 'Friend';\n\nconst menuText = `👋 السلام علیکم ${name}! KoderKids ERP میں خوش آمدید 🎓\n\nAssalam o Alaikum! Welcome to KoderKids ERP. How can I help you today?\n\nPlease reply with a number:\n\n1️⃣  Fee Enquiry (فیس)\n2️⃣  Lead / School Enquiry (لیڈ)\n3️⃣  Inventory / Stock (انوینٹری)\n4️⃣  Task Management (ٹاسک)\n5️⃣  General Help — Koder Agent\n\nOr just type your question and I will do my best to help! 😊`;\n\nreturn [\n  {\n    json: {\n      from: $input.item.json.from,\n      replyText: menuText,\n    }\n  }\n];"
      },
      "id": "3a1c8b2d-0006-4f7e-a123-000000000006",
      "name": "Build Welcome Menu",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1060, 100],
      "notes": "Builds the plain-text welcome/menu message. Called ONLY on greeting intent — this prevents the duplicate-first-message problem where both a welcome and an agent response were sent simultaneously."
    },
