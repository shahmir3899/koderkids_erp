    {
      "parameters": {
        "jsCode": "// Normalize responses from all upstream agent nodes into a single {from, replyText} shape.\n// Each input branch (fee, lead, inventory, task, koder) can have a different response schema.\nconst data = $input.item.json;\nconst from = data.from || '';\n\nlet replyText = '';\n\n// Welcome / menu node passes replyText directly\nif (data.replyText) {\n  replyText = data.replyText;\n\n// robot-reply / Koder Agent returns { reply: '...' }\n} else if (data.reply) {\n  replyText = data.reply;\n\n// AI execute endpoint returns { message: '...', success: true/false }\n} else if (data.message) {\n  replyText = data.message;\n\n// CRM lead creation returns { id, phone, status, ... }\n} else if (data.id && data.phone) {\n  replyText = `✅ Your enquiry has been logged! A KoderKids team member will contact you at +${data.phone} shortly.\\n\\nReference ID: #${data.id}`;\n\n// Fallback plain-text menu\n} else {\n  replyText = `I couldn't process your request right now. Please try again, or type *menu* to see available options.\\n\\n1️⃣ Fee\\n2️⃣ Lead Enquiry\\n3️⃣ Inventory\\n4️⃣ Task\\n5️⃣ General Help`;\n}\n\nreturn [{ json: { from, replyText } }];"
      },
      "id": "3a1c8b2d-0012-4f7e-a123-000000000012",
      "name": "Format Reply",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1320, 400],
      "notes": "Normalizes the response from all upstream branches (welcome, fee, lead, inventory, task, koder) into a consistent {from, replyText} object. If no meaningful response was produced, falls back to a plain-text menu."
    },
