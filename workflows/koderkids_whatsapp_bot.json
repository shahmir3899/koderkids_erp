      "id": "3a1c8b2d-0002-4f7e-a123-000000000002",
      "name": "Is Group Message?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [260, 300],
      "notes": "Filters out WhatsApp group messages. Group messages have a 'participant' field or a 'from' ending in @g.us. When true → ignore; when false → continue processing."
    },
    {
      "parameters": {},
      "id": "3a1c8b2d-0003-4f7e-a123-000000000003",
      "name": "Ignore Group Message",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [520, 100],
      "notes": "No action taken for group messages. The workflow stops here silently."
    },
    {
      "parameters": {
        "jsCode": "// Extract and normalize the incoming WhatsApp message payload.\n// Supports both the n8n WhatsApp Trigger output and raw Meta webhook payloads.\nconst data = $input.item.json;\n\n// --- phone number ---\n// n8n WhatsApp trigger exposes `from` directly at the top level.\nconst from = (data.from || '').replace(/[^0-9]/g, '');\n\n// --- message body ---\nconst msgType = (data.type || 'text');\nlet body = '';\nif (msgType === 'text') {\n  body = (data.text && data.text.body) ? data.text.body : (data.body || '');\n} else if (msgType === 'interactive') {\n  // Button / list reply\n  const interactive = data.interactive || {};\n  if (interactive.type === 'button_reply') {\n    body = interactive.button_reply?.id || interactive.button_reply?.title || '';\n  } else if (interactive.type === 'list_reply') {\n    body = interactive.list_reply?.id || interactive.list_reply?.title || '';\n  }\n} else {\n  // Unsupported types (image, audio, document, etc.) → route to Koder Agent\n  body = '__unsupported__';\n}\n\n// --- sender display name ---\n// The n8n WhatsApp trigger may include contacts array\nlet senderName = 'Friend';\nif (data.contacts && data.contacts.length > 0) {\n  senderName = data.contacts[0]?.profile?.name || 'Friend';\n} else if (data.pushName) {\n  senderName = data.pushName;\n}\n\n// --- message ID (for deduplication) ---\nconst messageId = data.id || data.messageId || '';\n\n// --- intent classification ---\nconst rawBody = body.trim();\nconst lc = rawBody.toLowerCase();\n\nlet intent = 'koder'; // default fallback\n\nif (rawBody === '__unsupported__') {\n  intent = 'unsupported';\n} else if (/^(hi|hello|hey|salam|start|menu|help|مرحبا|سلام|کوڈر|koder|helo|hii|hai)$/i.test(lc) || lc === '') {\n  intent = 'greeting';\n} else if (/^1$/.test(lc) || /\\bfee(s)?\\b/.test(lc) || /\\bpayment\\b/.test(lc) || /\\bfeature\\b/.test(lc)) {\n  intent = 'fee';\n} else if (/^2$/.test(lc) || /\\b(lead|enquiry|inquiry|prospect|school enquiry|new school)\\b/.test(lc)) {\n  intent = 'lead';\n} else if (/^3$/.test(lc) || /\\b(inventory|stock|item|supply|supplies|equipment)\\b/.test(lc)) {\n  intent = 'inventory';\n} else if (/^4$/.test(lc) || /\\b(task|todo|assign|assignment|reminder)\\b/.test(lc)) {\n  intent = 'task';\n} else if (/^5$/.test(lc) || /\\b(general|koder agent|assistant|bot|robot)\\b/.test(lc)) {\n  intent = 'koder';\n}\n// anything else falls through to the default 'koder' intent\n\nreturn [\n  {\n    json: {\n      from,\n      body: rawBody,\n      senderName,\n      messageId,\n      intent,\n      msgType,\n    }\n  }\n];"
      },
      "id": "3a1c8b2d-0004-4f7e-a123-000000000004",
      "name": "Extract & Classify Message",
      "type": "n8n-nodes-base.code",
