      "id": "3a1c8b2d-0005-4f7e-a123-000000000005",
      "name": "Route by Intent",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [780, 400],
      "notes": "Routes the message to the correct handler based on classified intent. Outputs: greeting, fee, lead, inventory, task, koder (fallback/default). All unmatched intents go to the Koder Agent."
